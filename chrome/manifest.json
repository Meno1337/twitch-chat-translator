{
  "manifest_version": 3,
  "name": "Twitch Chat Translator",
  "version": "1.3",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*.twitch.tv/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*", "https://twitch.tv/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/image16.png",
      "64": "icons/image64.png",
      "128": "icons/image128.png",
      "512": "icons/image512.png"
    }
  },
  "icons": {
    "16": "icons/image16.png",
    "64": "icons/image64.png",
    "128": "icons/image128.png",
    "512": "icons/image512.png"
  }
}
