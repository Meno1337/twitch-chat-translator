{
  "manifest_version": 3,
  "name": "Twitch Chat Translator",
  "version": "1.1",
  "author": "meno1337",
  "description": "Автоматический переводчик чата Twitch на русский язык.",
  "icons": {
    "16": "icons/image16.png",
    "64": "icons/image64.png",
    "128": "icons/image128.png"
  },
  "action": {
    "default_icon": "icons/image64.png",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.twitch.tv/*",
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "translator@meno1337.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}